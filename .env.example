# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=sciknow
PG_PASSWORD=sciknow
PG_DATABASE=sciknow

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Models ─────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
LLM_MODEL=qwen2.5:32b-instruct-q4_K_M
LLM_FAST_MODEL=mistral:7b-instruct-q4_K_M
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Crossref polite pool ───────────────────────────────────────────────────────
# Put your email here so Crossref gives you a higher rate limit
CROSSREF_EMAIL=you@example.com

# ── PDF converter backend ──────────────────────────────────────────────────────
# "auto"           — default post-54.6.212. Premium-first fallback chain:
#                    VLM-Pro → pipeline → Marker JSON → Marker markdown. The
#                    VLM-Pro step is silently skipped when `mineru[vllm]`
#                    extras aren't installed, so existing installations keep
#                    working under pipeline. New installations pick up
#                    VLM-Pro automatically.
# "mineru-vlm-pro" — MinerU 2.5-Pro VLM only (raises on failure). Requires
#                    `uv add 'mineru[vllm]'`. Use to verify VLM-Pro is healthy.
# "marker"         — legacy: Marker JSON → Marker markdown. Handy for pure scans
#                    that VLM-Pro can't OCR.
# "mineru"         — DEPRECATED (54.6.215). Pins MinerU 2.0 pipeline, OmniDocBench
#                    86.2 vs VLM-Pro's 95.69. Retained as auto-dispatch fallback;
#                    explicit pin emits a one-shot DeprecationWarning.
#
# MinerU 2.5-Pro VLM via vLLM runs 2-4× faster than the transformers backend
# on a 3090; see MINERU_VLM_BACKEND below.
PDF_CONVERTER_BACKEND=auto

# ── MinerU VLM inference backend ───────────────────────────────────────────────
# Consulted only when VLM-Pro is selected (PDF_CONVERTER_BACKEND=mineru-vlm-pro
# or auto dispatch routes to it).
#   "auto"         — let MinerU pick (vllm if `mineru[vllm]` installed,
#                    transformers otherwise).
#   "vllm"         — force vllm-engine path (default; requires `mineru[vllm]`).
#   "transformers" — force HF transformers path (slower, no vllm prereq).
MINERU_VLM_BACKEND=vllm

# MinerU 2.5-Pro VLM model identifier on HuggingFace / ModelScope.
MINERU_VLM_MODEL=opendatalab/MinerU2.5-Pro-2604-1.2B

# ── CORE (core.ac.uk) OA resolver ──────────────────────────────────────────────
# Free API key for the CORE (institutional-repository aggregator) resolver in
# the OA cascade. Register at https://core.ac.uk/services/api. Leave unset to
# skip CORE — the cascade still works on the other 8 sources.
# CORE_API_KEY=

# ── Ingestion ──────────────────────────────────────────────────────────────────
# Chunks per bge-m3 batch. 32 is safe on a 24GB GPU with a 32B LLM co-resident.
# Raise to 64-128 when running embedder-only (no LLM on the same GPU).
EMBEDDING_BATCH_SIZE=32

# Marker batch_multiplier — how many pages Marker batches per forward pass.
# Each unit ≈ 5GB VRAM peak. Keep at 2 on a 24GB GPU, raise to 4 only when
# the LLM is off-GPU (e.g. remote Ollama on DGX Spark).
MARKER_BATCH_MULTIPLIER=2

# ── Database tuning ────────────────────────────────────────────────────────────
PG_POOL_SIZE=20
PG_MAX_OVERFLOW=20

# ── Qdrant tuning ──────────────────────────────────────────────────────────────
# HNSW params — higher m / ef_construct means better recall at index cost.
# These apply only when a collection is CREATED; existing collections are untouched.
QDRANT_HNSW_M=32
QDRANT_HNSW_EF_CONSTRUCT=256
QDRANT_HNSW_EF=128
# Scalar int8 quantization: ~75% memory savings, quantized vectors kept in RAM
# while originals stay on disk. Tiny recall impact with rescoring.
QDRANT_SCALAR_QUANTIZATION=true

# ── Bulk-op concurrency ────────────────────────────────────────────────────────
# Concurrent workers for Crossref/OpenAlex lookups in `db enrich`
ENRICH_WORKERS=8
# Concurrent workers for Unpaywall/arXiv/S2 lookups+downloads in `db expand`
EXPAND_DOWNLOAD_WORKERS=6
# Concurrent LLM calls issued by bulk commands (catalog cluster, db export --generate-qa).
# MUST be <= OLLAMA_NUM_PARALLEL on the Ollama server (server default is 1!).
# To raise it on the Ollama server: systemctl --user edit ollama  (add Environment=OLLAMA_NUM_PARALLEL=4)
LLM_PARALLEL_WORKERS=4

# Parallel `sciknow ingest directory` worker subprocesses. Each loads its own
# Marker (~5GB VRAM) + bge-m3 (~2.2GB). Keep at 1 on a 24GB GPU with an LLM
# resident (e.g. Ollama-held 32B q4 ~18GB). Raise to 2 only when the LLM is
# off-GPU (no Ollama model loaded, or LLM moved to DGX Spark).
# Override per-run with `sciknow ingest directory --workers N`.
INGEST_WORKERS=1
