# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=sciknow
PG_PASSWORD=sciknow
PG_DATABASE=sciknow

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Models ─────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
LLM_MODEL=qwen2.5:32b-instruct-q4_K_M
LLM_FAST_MODEL=mistral:7b-instruct-q4_K_M
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Crossref polite pool ───────────────────────────────────────────────────────
# Put your email here so Crossref gives you a higher rate limit
CROSSREF_EMAIL=you@example.com

# ── PDF converter backend ──────────────────────────────────────────────────────
# "auto"   — MinerU 2.5 primary, falls back to Marker JSON → Marker markdown (default)
# "mineru" — MinerU only, no fallback (raises on failure)
# "marker" — legacy: Marker JSON → Marker markdown
#
# MinerU is better for scientific papers (dedicated formula/table models,
# OmniDocBench SOTA). Requires `uv add "mineru[core]"`. Models (~2GB) auto-
# download to ~/.cache/modelscope on first run.
PDF_CONVERTER_BACKEND=auto

# ── Ingestion ──────────────────────────────────────────────────────────────────
# Chunks per bge-m3 batch. 32 is safe on a 24GB GPU with a 32B LLM co-resident.
# Raise to 64-128 when running embedder-only (no LLM on the same GPU).
EMBEDDING_BATCH_SIZE=32

# Marker batch_multiplier — how many pages Marker batches per forward pass.
# Each unit ≈ 5GB VRAM peak. Keep at 2 on a 24GB GPU, raise to 4 only when
# the LLM is off-GPU (e.g. remote Ollama on DGX Spark).
MARKER_BATCH_MULTIPLIER=2

# ── Database tuning ────────────────────────────────────────────────────────────
PG_POOL_SIZE=20
PG_MAX_OVERFLOW=20

# ── Qdrant tuning ──────────────────────────────────────────────────────────────
# HNSW params — higher m / ef_construct means better recall at index cost.
# These apply only when a collection is CREATED; existing collections are untouched.
QDRANT_HNSW_M=32
QDRANT_HNSW_EF_CONSTRUCT=256
QDRANT_HNSW_EF=128
# Scalar int8 quantization: ~75% memory savings, quantized vectors kept in RAM
# while originals stay on disk. Tiny recall impact with rescoring.
QDRANT_SCALAR_QUANTIZATION=true

# ── Bulk-op concurrency ────────────────────────────────────────────────────────
# Concurrent workers for Crossref/OpenAlex lookups in `db enrich`
ENRICH_WORKERS=8
# Concurrent workers for Unpaywall/arXiv/S2 lookups+downloads in `db expand`
EXPAND_DOWNLOAD_WORKERS=6
# Concurrent LLM calls issued by bulk commands (catalog cluster, db export --generate-qa).
# MUST be <= OLLAMA_NUM_PARALLEL on the Ollama server (server default is 1!).
# To raise it on the Ollama server: systemctl --user edit ollama  (add Environment=OLLAMA_NUM_PARALLEL=4)
LLM_PARALLEL_WORKERS=4

# Parallel `sciknow ingest directory` worker subprocesses. Each loads its own
# Marker (~5GB VRAM) + bge-m3 (~2.2GB). Keep at 1 on a 24GB GPU with an LLM
# resident (e.g. Ollama-held 32B q4 ~18GB). Raise to 2 only when the LLM is
# off-GPU (no Ollama model loaded, or LLM moved to DGX Spark).
# Override per-run with `sciknow ingest directory --workers N`.
INGEST_WORKERS=1
