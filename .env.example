# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=sciknow
PG_PASSWORD=sciknow
PG_DATABASE=sciknow

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Ollama ─────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Models ─────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
LLM_MODEL=qwen2.5:32b-instruct-q4_K_M
LLM_FAST_MODEL=mistral:7b-instruct-q4_K_M
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── Crossref polite pool ───────────────────────────────────────────────────────
# Put your email here so Crossref gives you a higher rate limit
CROSSREF_EMAIL=you@example.com

# ── Ingestion ──────────────────────────────────────────────────────────────────
EMBEDDING_BATCH_SIZE=8
